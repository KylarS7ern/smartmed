{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SmartMed: App starten (lokal)",
            "type": "debugpy",
            "request": "launch",
            "module": "smartmed.main",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "SmartMed: Alle Tests ausführen",
            "type": "debugpy",
            "request": "launch",
            "module": "unittest",
            "args": ["discover", "-s", "tests"],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
