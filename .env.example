SMARTMED_TELEGRAM_BOT_TOKEN=
SMARTMED_EMAIL_SMTP_SERVER=smtp.gmail.com
SMARTMED_EMAIL_SMTP_PORT=587
SMARTMED_EMAIL_USERNAME=smartmedispender@gmail.com
SMARTMED_EMAIL_PASSWORT=
SMARTMED_ARDUINO_PORT=/dev/ttyACM0
SMARTMED_ARDUINO_BAUDRATE=115200
SMARTMED_ARDUINO_TIMEOUT=1

# Auf dem Pi mit echtem Arduino: real (Standard, einfach weglassen)
# Lokale Entwicklung am Laptop ohne Arduino: mock
SMARTMED_HARDWARE_MODE=real

# Auf dem Pi (Touchscreen-Kiosk): 1 (Standard, einfach weglassen)
# Lokale Entwicklung am Laptop (normales Fenster statt Vollbild): 0
SMARTMED_KIOSK=1
